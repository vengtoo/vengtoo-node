{
  "name": "@authzx/sdk",
  "version": "0.3.0",
  "description": "AuthzX Node.js SDK — authorization client for AuthzX Cloud and the AuthzX Agent",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "!dist/**/*.test.*"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --experimental-strip-types src/index.test.ts",
    "prepublishOnly": "npm run build"
