    "type": "git",
    "url": "git+https://github.com/authzx/node-sdk.git"
  },
  "homepage": "https://authzx.com",
  "bugs": {
    "url": "https://github.com/authzx/node-sdk/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.4.0"
  }
